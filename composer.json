{
  "name": "financeiro-pro-whats/saas",
  "type": "project",
  "description": "SaaS multi-tenant de gestao financeira, cobrancas e automacoes para WhatsApp.",
  "keywords": [
    "laravel",
    "saas",
    "multi-tenant",
    "whatsapp",
    "financeiro"
  ],
  "license": "proprietary",
  "require": {
    "php": "^8.4",
    "laravel/framework": "^12.0",
    "laravel/sanctum": "^4.0",
    "laravel/tinker": "^2.10",
    "spatie/laravel-permission": "^6.0",
    "stripe/stripe-php": "^15.0",
    "mercadopago/dx-php": "^3.9",
    "efipay/sdk-php-apis-efi": "^1.0",
    "pragmarx/google2fa": "^8.0",
    "spatie/laravel-activitylog": "^4.7",
    "spatie/laravel-backup": "^10.0",
    "guzzlehttp/guzzle": "^7.8"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "laravel/pint": "^1.18",
    "laravel/sail": "^1.41",
    "mockery/mockery": "^1.6",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": [
        "nunomaduro/collision"
      ]
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
